# Copy this file to ".env" and fill in your key.
# Get a free key at https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key_here

# Optional. Default is a fast, capable model.
# Other good options: llama-3.1-8b-instant (fastest/cheapest), openai/gpt-oss-20b
GROQ_MODEL=llama-3.1-8b-instant

# Optional. Port the server listens on.
PORT=3000
